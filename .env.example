# Anthropic API key for Claude AI fallback extraction
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI API key for transaction categorization (GPT-4o-mini)
OPENAI_API_KEY=your_openai_key_here

# Supabase database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# LangTrace observability (optional)
LANGTRACE_API_KEY=your_langtrace_key_here

# Frontend (Next.js) — see also web/.env.example
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_FASTAPI_URL=http://127.0.0.1:8000
